@model AI_Resume.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Create Account";
}

<div class="auth-page">
    <div class="auth-left">
        <div class="auth-left-content">
            <div class="auth-brand">
                <div class="auth-brand-icon"><i class="fas fa-file-alt"></i></div>
                <span>AI <span class="gold">Resume</span> Studio</span>
            </div>
            <h2 class="auth-left-title">Start Building Your Career Story.</h2>
            <p class="auth-left-sub">Create your free account and get access to AI-powered resume building, analysis, scoring, and PDF export — all in one place.</p>
            <div class="auth-features">
                <div class="af-item"><i class="fas fa-check-circle"></i> Free to use — no credit card</div>
                <div class="af-item"><i class="fas fa-check-circle"></i> AI resume score out of 100</div>
                <div class="af-item"><i class="fas fa-check-circle"></i> Upload existing resumes for analysis</div>
                <div class="af-item"><i class="fas fa-check-circle"></i> Export polished PDF in one click</div>
            </div>
        </div>
    </div>

    <div class="auth-right">
        <div class="auth-form-box">
            <div class="auth-form-header">
                <h3>Create Your Free Account</h3>
                <p>Already have an account? <a asp-action="Login">Sign in here</a></p>
            </div>

            <form asp-action="Register" method="post">
                <div asp-validation-summary="ModelOnly" class="auth-alert" role="alert"></div>

                <div class="auth-field">
                    <label asp-for="FullName" class="auth-label">
                        <i class="fas fa-user"></i> Full Name
                    </label>
                    <input asp-for="FullName" class="auth-input" placeholder="John Doe" autocomplete="name" />
                    <span asp-validation-for="FullName" class="auth-error"></span>
                </div>

                <div class="auth-field">
                    <label asp-for="Email" class="auth-label">
                        <i class="fas fa-envelope"></i> Email Address
                    </label>
                    <input asp-for="Email" class="auth-input" placeholder="you@example.com" autocomplete="email" />
                    <span asp-validation-for="Email" class="auth-error"></span>
                </div>

                <div class="auth-field">
                    <label asp-for="Password" class="auth-label">
                        <i class="fas fa-lock"></i> Password
                    </label>
                    <div class="auth-input-wrap">
                        <input asp-for="Password" class="auth-input" id="passwordField" placeholder="Min. 6 characters" autocomplete="new-password" />
                        <button type="button" class="toggle-pw" onclick="togglePassword('passwordField','eyeIcon1')">
                            <i class="fas fa-eye" id="eyeIcon1"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="auth-error"></span>
                </div>

                <div class="auth-field">
                    <label asp-for="ConfirmPassword" class="auth-label">
                        <i class="fas fa-lock"></i> Confirm Password
                    </label>
                    <div class="auth-input-wrap">
                        <input asp-for="ConfirmPassword" class="auth-input" id="confirmField" placeholder="Repeat your password" autocomplete="new-password" />
                        <button type="button" class="toggle-pw" onclick="togglePassword('confirmField','eyeIcon2')">
                            <i class="fas fa-eye" id="eyeIcon2"></i>
                        </button>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="auth-error"></span>
                </div>

                <div class="auth-terms">
                    By creating an account, you agree that your data is stored securely and used only to power your resume features.
                </div>

                <button type="submit" class="auth-submit">
                    <i class="fas fa-rocket"></i> Create Account
                </button>
            </form>
        </div>
    </div>
</div>

<style>
.auth-page {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: calc(100vh - 130px);
    margin: -2rem 0 0;
}
@@media(max-width:768px) {
    .auth-page { grid-template-columns: 1fr; }
    .auth-left { display: none; }
}
.auth-left {
    background: var(--navy);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3rem 3.5rem;
    position: relative;
    overflow: hidden;
}
.auth-left::before {
    content: '';
    position: absolute;
    width: 400px; height: 400px;
    border-radius: 50%;
    background: rgba(201,168,76,0.06);
    top: -100px; right: -100px;
}
.auth-left::after {
    content: '';
    position: absolute;
    width: 250px; height: 250px;
    border-radius: 50%;
    background: rgba(201,168,76,0.04);
    bottom: -60px; left: -60px;
}
.auth-left-content { position: relative; z-index: 1; }
.auth-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 1.2rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 2.5rem;
}
.auth-brand-icon {
    width: 36px; height: 36px;
    background: var(--gold);
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    color: var(--navy);
    font-size: 1rem;
}
.auth-brand .gold { color: var(--gold); }
.auth-left-title {
    font-size: 2rem;
    font-weight: 800;
    color: #fff;
    margin-bottom: 1rem;
    line-height: 1.2;
    letter-spacing: -0.02em;
}
.auth-left-sub {
    color: rgba(255,255,255,0.55);
    font-size: 0.92rem;
    line-height: 1.75;
    margin-bottom: 2rem;
}
.auth-features { display: flex; flex-direction: column; gap: 0.7rem; }
.af-item {
    display: flex;
    align-items: center;
    gap: 10px;
    color: rgba(255,255,255,0.7);
    font-size: 0.875rem;
}
.af-item i { color: var(--gold); font-size: 0.85rem; }

.auth-right {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3rem 2rem;
    background: var(--off-white);
}
.auth-form-box { width: 100%; max-width: 420px; }
.auth-form-header { margin-bottom: 1.75rem; }
.auth-form-header h3 {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--navy);
    margin-bottom: 0.4rem;
    letter-spacing: -0.01em;
}
.auth-form-header p { font-size: 0.875rem; color: var(--text-muted); margin: 0; }
.auth-form-header a { color: var(--navy-mid); font-weight: 600; text-decoration: none; }
.auth-form-header a:hover { color: var(--gold-dark); }

.auth-alert {
    background: #fff3f3;
    border: 1px solid #f5c6cb;
    color: #721c24;
    border-radius: 8px;
    padding: 0.75rem 1rem;
    font-size: 0.85rem;
    margin-bottom: 1.25rem;
}
.auth-field { margin-bottom: 1.1rem; }
.auth-label {
    display: block;
    font-size: 0.84rem;
    font-weight: 600;
    color: var(--navy);
    margin-bottom: 0.35rem;
}
.auth-label i { color: var(--gold-dark); margin-right: 4px; font-size: 0.78rem; }
.auth-input {
    width: 100%;
    border: 1.5px solid #dde2eb;
    border-radius: 8px;
    padding: 0.65rem 1rem;
    font-size: 0.92rem;
    color: var(--navy);
    background: #fff;
    transition: all 0.2s;
    outline: none;
}
.auth-input:focus {
    border-color: var(--gold);
    box-shadow: 0 0 0 3px rgba(201,168,76,0.12);
}
.auth-input-wrap { position: relative; }
.auth-input-wrap .auth-input { padding-right: 2.8rem; }
.toggle-pw {
    position: absolute;
    right: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    font-size: 0.9rem;
    padding: 0;
    transition: color 0.2s;
}
.toggle-pw:hover { color: var(--navy); }
.auth-error { display: block; font-size: 0.78rem; color: #dc3545; margin-top: 0.25rem; }
.auth-terms {
    font-size: 0.75rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 1.25rem;
    padding: 0.6rem 0.9rem;
    background: rgba(10,22,40,0.03);
    border-radius: 6px;
    border-left: 3px solid rgba(201,168,76,0.4);
}
.auth-submit {
    width: 100%;
    background: var(--navy);
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: 0.85rem;
    font-size: 0.95rem;
    font-weight: 700;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    transition: all 0.2s;
}
.auth-submit:hover {
    background: var(--navy-mid);
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(10,22,40,0.25);
}
</style>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        function togglePassword(fieldId, iconId) {
            const f = document.getElementById(fieldId);
            const i = document.getElementById(iconId);
            if (f.type === 'password') {
                f.type = 'text';
                i.classList.replace('fa-eye', 'fa-eye-slash');
            } else {
                f.type = 'password';
                i.classList.replace('fa-eye-slash', 'fa-eye');
            }
        }
    </script>
}
