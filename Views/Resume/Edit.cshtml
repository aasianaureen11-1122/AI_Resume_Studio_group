@model Resume
@using AI_Resume.Models

@{
    ViewData["Title"] = "Edit Resume";
}

<div class="page-header">
    <div class="container">
        <div class="d-flex align-items-center gap-3">
            <div style="width:48px;height:48px;background:rgba(201,168,76,0.15);border-radius:10px;display:flex;align-items:center;justify-content:center;">
                <i class="fas fa-edit" style="color:var(--gold);font-size:1.3rem;"></i>
            </div>
            <div>
                <h1><span>Edit</span> Resume</h1>
                <p>Update your resume details — changes are saved instantly</p>
            </div>
        </div>
    </div>
</div>

<div class="container" style="max-width:860px;">
    <form asp-action="Edit" method="post">
        <input asp-for="Id" type="hidden" />
        <input asp-for="UserId" type="hidden" />
        <input asp-for="CreatedAt" type="hidden" />

        <!-- PERSONAL INFORMATION -->
        <div class="card mb-4">
            <div class="card-header">
                <i class="fas fa-user"></i> Personal Information
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="FullName" class="form-label">Full Name <span style="color:#dc3545;">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text" style="background:#f4f6fa;border:1.5px solid #dde2eb;border-right:none;border-radius:8px 0 0 8px;color:var(--text-muted);"><i class="fas fa-user"></i></span>
                            <input asp-for="FullName" class="form-control" style="border-left:none;border-radius:0 8px 8px 0;" />
                        </div>
                        <span asp-validation-for="FullName" class="text-danger" style="font-size:0.82rem;"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label">Email Address <span style="color:#dc3545;">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text" style="background:#f4f6fa;border:1.5px solid #dde2eb;border-right:none;border-radius:8px 0 0 8px;color:var(--text-muted);"><i class="fas fa-envelope"></i></span>
                            <input asp-for="Email" class="form-control" style="border-left:none;border-radius:0 8px 8px 0;" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Phone" class="form-label">Phone Number</label>
                        <div class="input-group">
                            <span class="input-group-text" style="background:#f4f6fa;border:1.5px solid #dde2eb;border-right:none;border-radius:8px 0 0 8px;color:var(--text-muted);"><i class="fas fa-phone"></i></span>
                            <input asp-for="Phone" class="form-control" style="border-left:none;border-radius:0 8px 8px 0;" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="JobTitle" class="form-label">Job Title / Target Role</label>
                        <div class="input-group">
                            <span class="input-group-text" style="background:#f4f6fa;border:1.5px solid #dde2eb;border-right:none;border-radius:8px 0 0 8px;color:var(--text-muted);"><i class="fas fa-briefcase"></i></span>
                            <input asp-for="JobTitle" class="form-control" style="border-left:none;border-radius:0 8px 8px 0;" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="LinkedIn" class="form-label">LinkedIn Profile</label>
                        <div class="input-group">
                            <span class="input-group-text" style="background:#f4f6fa;border:1.5px solid #dde2eb;border-right:none;border-radius:8px 0 0 8px;color:var(--text-muted);"><i class="fab fa-linkedin"></i></span>
                            <input asp-for="LinkedIn" class="form-control" style="border-left:none;border-radius:0 8px 8px 0;" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Location" class="form-label">Location</label>
                        <div class="input-group">
                            <span class="input-group-text" style="background:#f4f6fa;border:1.5px solid #dde2eb;border-right:none;border-radius:8px 0 0 8px;color:var(--text-muted);"><i class="fas fa-map-marker-alt"></i></span>
                            <input asp-for="Location" class="form-control" style="border-left:none;border-radius:0 8px 8px 0;" />
                        </div>
                    </div>
                    <div class="col-12">
                        <label asp-for="Summary" class="form-label">Professional Summary</label>
                        <textarea asp-for="Summary" class="form-control" rows="4" placeholder="Write a brief professional summary..."></textarea>
                        <div style="font-size:0.78rem;color:var(--text-muted);margin-top:4px;"><i class="fas fa-lightbulb" style="color:var(--gold);"></i> Tip: Keep it between 3–5 sentences. Focus on your strengths and value.</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- AI SCORES (read-only display if available) -->
        @if (Model.AIScore.HasValue)
        {
            <div class="card mb-4" style="border-left:4px solid var(--gold);">
                <div class="card-header" style="background:var(--navy-light);">
                    <i class="fas fa-robot"></i> AI Analysis Results
                    <span class="badge-gold ms-auto">Score: @Model.AIScore/100</span>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        @if (!string.IsNullOrEmpty(Model.AISummary))
                        {
                            <div class="col-12">
                                <label class="form-label" style="color:var(--text-muted);">AI Summary</label>
                                <p style="background:#f4f6fa;padding:1rem;border-radius:8px;margin:0;font-size:0.9rem;">@Model.AISummary</p>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.AISkillGaps))
                        {
                            <div class="col-md-6">
                                <label class="form-label" style="color:var(--text-muted);">Skill Gaps</label>
                                <p style="background:#fff3cd;padding:1rem;border-radius:8px;margin:0;font-size:0.9rem;">@Model.AISkillGaps</p>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.AIImprovements))
                        {
                            <div class="col-md-6">
                                <label class="form-label" style="color:var(--text-muted);">Suggested Improvements</label>
                                <p style="background:#d1e7dd;padding:1rem;border-radius:8px;margin:0;font-size:0.9rem;">@Model.AIImprovements</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

        <!-- ACTION BUTTONS -->
        <div class="d-flex align-items-center justify-content-between gap-3 mb-5">
            <a asp-action="Index" class="btn-outline-custom">
                <i class="fas fa-arrow-left"></i> Back to Resumes
            </a>
            <div class="d-flex gap-3">
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn-outline-custom">
                    <i class="fas fa-eye"></i> Preview
                </a>
                <button type="submit" class="btn-primary-custom">
                    <i class="fas fa-save"></i> Update Resume
                </button>
                <button type="submit" class="btn-gold">
                    <i class="fas fa-magic"></i> Update & Re-Analyze
                </button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
