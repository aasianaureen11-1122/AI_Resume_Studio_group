@model List<Resume>
@using AI_Resume.Models
@if (TempData["AIScore"] != null)
{
    <div class="alert alert-success mt-3">
        <h4>AI Resume Analysis</h4>
        <p><strong>Score:</strong> @TempData["AIScore"] / 100</p>
        <p><strong>Summary:</strong> @TempData["AISummary"]</p>
        <p><strong>Skill Gaps:</strong> @TempData["AISkillGaps"]</p>
        <p><strong>Improvements:</strong> @TempData["AIImprovements"]</p>
    </div>
}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>My Resumes</h2>
        <a asp-action="Create" class="btn btn-primary">+ New Resume</a>

        <a href="/Resume/UploadResume" class="btn btn-outline-success me-2">
    📄 Upload & Analyze Resume
</a>
    </div>

 

    @if (!Model.Any())
    {
        <p class="text-muted">You haven't created any resumes yet.</p>
    }
    else
    {
        <div class="row">
            @foreach (var resume in Model)
            {
                <div class="col-md-4 mb-3">
                    <div class="card shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title">@resume.FullName</h5>
                            <p class="card-text text-muted">@resume.JobTitle</p>
                            <p class="card-text"><small>Created: @resume.CreatedAt.ToShortDateString()</small></p>
                            <a asp-action="Details" asp-route-id="@resume.Id" class="btn btn-sm btn-outline-primary">View</a>
                            <a asp-action="Edit" asp-route-id="@resume.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                            <a asp-action="Delete" asp-route-id="@resume.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                            <a asp-action="GenerateAI" asp-route-id="@resume.Id" 
   class="btn btn-sm btn-success">
   ✨ Generate AI Resume
</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>