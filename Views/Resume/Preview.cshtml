
@model AI_Resume.Models.Resume
@{
    ViewData["Title"] = "Resume Preview";
    Layout = null;   // Full-page, no navbar — feels like a real document
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@Model.FullName — Resume</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <style>
        body { background: #f1f3f5; font-family: 'Georgia', serif; }

        /* ── Floating toolbar ── */
        .preview-toolbar {
            position: fixed; top: 0; left: 0; right: 0; z-index: 100;
            background: #1e3a5f; color: #fff;
            display: flex; align-items: center; justify-content: space-between;
            padding: 10px 24px;
        }
        .preview-toolbar .brand { font-size: 15px; font-weight: 600; letter-spacing: .3px; }
        .preview-toolbar .actions { display: flex; gap: 10px; }
        .btn-toolbar-action {
            border: 1px solid rgba(255,255,255,.35); background: transparent; color: #fff;
            border-radius: 6px; padding: 5px 14px; font-size: 13px; cursor: pointer;
            transition: background .15s;
        }
        .btn-toolbar-action:hover { background: rgba(255,255,255,.1); }
        .btn-toolbar-download {
            background: #fff; color: #1e3a5f; border: none;
            border-radius: 6px; padding: 5px 16px; font-size: 13px; font-weight: 600;
            cursor: pointer; transition: opacity .15s;
        }
        .btn-toolbar-download:hover { opacity: .85; }

        /* ── Resume document ── */
        .resume-page {
            margin: 70px auto 40px;
            max-width: 800px;
            background: #fff;
            box-shadow: 0 4px 32px rgba(0,0,0,.12);
            border-radius: 2px;
        }

        /* ── CLASSIC styles ── */
        .tpl-classic .rh {
            border-bottom: 2px solid #1a1a1a;
            padding: 32px 40px 18px;
        }
        .tpl-classic .rh h1 { font-size: 2.1rem; margin: 0 0 2px; font-weight: 700; }
        .tpl-classic .rh .tagline { color: #555; font-size: 1rem; }
        .tpl-classic .rh .contact-row { font-size: .83rem; color: #666; margin-top: 6px; }
        .tpl-classic .rb { padding: 24px 40px; }
        .tpl-classic .section-title {
            font-size: .78rem; text-transform: uppercase; letter-spacing: 2.5px;
            border-bottom: 1px solid #ccc; padding-bottom: 4px; margin: 22px 0 10px;
            color: #1a1a1a;
        }

        /* ── MODERN styles ── */
        .tpl-modern .rh {
            background: #1e3a5f; color: #fff;
            padding: 32px 40px 24px;
        }
        .tpl-modern .rh h1 { font-family: Arial, sans-serif; font-size: 2rem; margin: 0 0 3px; }
        .tpl-modern .rh .tagline { color: #90b8d8; font-family: Arial, sans-serif; }
        .tpl-modern .rh .contact-row { font-size: .82rem; color: #b0cce0; margin-top: 8px; font-family: Arial, sans-serif; }
        .tpl-modern .rb { padding: 24px 40px; font-family: Arial, sans-serif; }
        .tpl-modern .section-title {
            font-size: .78rem; text-transform: uppercase; letter-spacing: 2px;
            border-left: 3px solid #1e3a5f; padding-left: 8px; margin: 22px 0 10px;
            color: #1e3a5f;
        }
        .tpl-modern .skill-pill { background: #1e3a5f; color: #fff; border-radius: 20px; }

        /* ── MINIMAL styles ── */
        .tpl-minimal .rh { padding: 36px 40px 22px; }
        .tpl-minimal .rh h1 {
            font-family: 'Helvetica Neue', sans-serif;
            font-size: 2.2rem; font-weight: 300; letter-spacing: -0.5px; margin: 0 0 3px;
        }
        .tpl-minimal .rh .tagline { color: #999; font-family: 'Helvetica Neue', sans-serif; font-weight: 300; }
        .tpl-minimal .rh .contact-row { font-size: .82rem; color: #aaa; margin-top: 6px; font-family: 'Helvetica Neue', sans-serif; }
        .tpl-minimal .rb { padding: 24px 40px; font-family: 'Helvetica Neue', sans-serif; }
        .tpl-minimal .section-title {
            font-size: .7rem; text-transform: uppercase; letter-spacing: 3px; color: #bbb; margin: 22px 0 8px;
        }
        .tpl-minimal .entry { border-bottom: .5px solid #eee; padding-bottom: 12px; margin-bottom: 12px; }
        .tpl-minimal .skill-pill { border-bottom: 1px solid #ccc; border-radius: 0; padding: 0 0 2px; background: transparent; color: #333; }

        /* ── Shared entry styles ── */
        .entry { margin-bottom: 14px; }
        .entry-header { display: flex; justify-content: space-between; align-items: baseline; }
        .entry-title { font-weight: 700; font-size: .95rem; }
        .entry-date { font-size: .8rem; color: #777; }
        .entry-sub { font-size: .85rem; color: #666; margin: 1px 0 4px; font-style: italic; }
        .entry-body { font-size: .88rem; line-height: 1.55; color: #333; margin: 0; }
        .summary-text { font-size: .9rem; line-height: 1.65; color: #333; }
        .skills-grid { display: flex; flex-wrap: wrap; gap: 8px; }
        .skill-pill { border: 1px solid #999; border-radius: 4px; padding: 3px 10px; font-size: .8rem; }
        .contact-item { display: inline-flex; align-items: center; gap: 4px; margin-right: 12px; }
    </style>
</head>
<body>

<!-- Toolbar -->
<div class="preview-toolbar">
    <span class="brand"><i class="bi bi-file-earmark-person me-1"></i> AI Resume Studio — Preview</span>
    <div class="actions">
        <a href="@Url.Action("SelectTemplate", "Resume", new { id = Model.Id })"
           class="btn-toolbar-action"><i class="bi bi-palette me-1"></i> Change Template</a>
        <a href="@Url.Action("Edit", "Resume", new { id = Model.Id })"
           class="btn-toolbar-action"><i class="bi bi-pencil me-1"></i> Edit Resume</a>
        <a href="@Url.Action("DownloadPdf", "Resume", new { id = Model.Id })"
           class="btn-toolbar-download"><i class="bi bi-download me-1"></i> Download PDF</a>
    </div>
</div>

<!-- Resume Document -->
@{
    string tpl = (Model.Template ?? "Classic").ToLower();
}
<div class="resume-page tpl-@tpl">

    <!-- Header -->
    <div class="rh">
        <h1>@Model.FullName</h1>
        <p class="tagline mb-1">@Model.JobTitle</p>
        <div class="contact-row">
            @if (!string.IsNullOrEmpty(Model.Email))
            {
                <span class="contact-item"><i class="bi bi-envelope"></i> @Model.Email</span>
            }
            @if (!string.IsNullOrEmpty(Model.Phone))
            {
                <span class="contact-item"><i class="bi bi-telephone"></i> @Model.Phone</span>
            }
            @if (!string.IsNullOrEmpty(Model.Location))
            {
                <span class="contact-item"><i class="bi bi-geo-alt"></i> @Model.Location</span>
            }
            @if (!string.IsNullOrEmpty(Model.LinkedIn))
            {
                <span class="contact-item"><i class="bi bi-linkedin"></i> @Model.LinkedIn</span>
            }
        </div>
    </div>

    <!-- Body -->
    <div class="rb">

        @if (!string.IsNullOrEmpty(Model.Summary))
        {
            <h2 class="section-title">Professional Summary</h2>
            <p class="summary-text">@Model.Summary</p>
        }

        @if (Model.WorkExperiences != null && Model.WorkExperiences.Any())
        {
            <h2 class="section-title">Work Experience</h2>
            @foreach (var w in Model.WorkExperiences.OrderByDescending(x => x.StartDate))
            {
                <div class="entry">
                    <div class="entry-header">
                        <span class="entry-title">@w.JobTitle</span>
                        <span class="entry-date">,
                            @w.StartDate.ToString("MMM yyyy") – @(w.IsCurrent ? "Present" : w.EndDate.ToString("MMM yyyy"))
                            
                        </span>
                    </div>
                    <p class="entry-sub">@w.Company@(string.IsNullOrEmpty(w.Location) ? "" : ", " + w.Location)</p>
                    @if (!string.IsNullOrEmpty(w.Description))
                    {
                        <p class="entry-body">@w.Description</p>
                    }
                </div>
            }
        }

        @if (Model.Educations != null && Model.Educations.Any())
        {
            <h2 class="section-title">Education</h2>
            @foreach (var e in Model.Educations.OrderByDescending(x => x.StartYear))
            {
                <div class="entry">
                    <div class="entry-header">
                        <span class="entry-title">@e.Degree in @e.FieldOfStudy</span>
                        <span class="entry-date">@e.StartYear –@(e.EndYear > 0 ? e.EndYear.ToString() : "Present")</span>
                    </div>
                    <p class="entry-sub">@e.Institution</p>
                    @if (!string.IsNullOrEmpty(e.Description))
                    {
                        <p class="entry-body">@e.Description</p>
                    }
                </div>
            }
        }

        @if (Model.Skills != null && Model.Skills.Any())
        {
            <h2 class="section-title">Skills</h2>
            <div class="skills-grid">
                @foreach (var s in Model.Skills)
                {
                    <span class="skill-pill">@s.Name</span>
                }
            </div>
        }

    </div>
</div>

</body>
</html>

